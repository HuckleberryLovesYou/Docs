      "id": "ycU2U0BKjfAEbbPM8-f1X",
      "type": "text",
      "x": 569.2448217711639,
      "y": 1371.73741735467,
      "width": 1169.7916259765625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aq",
      "roundness": null,
      "seed": 1043863803,
      "version": 475,
      "versionNonce": 339539102,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "xfDZFV3L3SIPyI5AbPsJb",
          "type": "arrow"
        }
      ],
      "updated": 1773914348718,
      "link": null,
      "locked": false,
      "text": "Somit ist das erste Netz 192.168.254.0/25; Netzadresse 192.168.254.0; Broadcast Adresse 192.168.254.127\nNun fange ich an, das rechteste Bit der IP, welche von der Subnetzmaske bedeckt wird, um binär 1 hochzuzählen\nDas zweite ist dann das Netz 192.168.254.128/25; Netzadresse 192.168.254.128; Broadcast Adresse 192.168.254.255",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Somit ist das erste Netz 192.168.254.0/25; Netzadresse 192.168.254.0; Broadcast Adresse 192.168.254.127\nNun fange ich an, das rechteste Bit der IP, welche von der Subnetzmaske bedeckt wird, um binär 1 hochzuzählen\nDas zweite ist dann das Netz 192.168.254.128/25; Netzadresse 192.168.254.128; Broadcast Adresse 192.168.254.255",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "d0dcIGJSoKVLA5ikSsuWC",
      "type": "text",
      "x": 564.0892542359684,
      "y": 1196.4504319913788,
      "width": 1471,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ar",
      "roundness": null,
      "seed": 889442357,
      "version": 204,
      "versionNonce": 296791106,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773914348718,
      "link": null,
      "locked": false,
      "text": "Zur Errechnung der Broadcast Adresse des 1. Netzes setzen wir alle nicht durch die Subnetzmaske gesperrte Bits auf 1 und rechnen sie in Deziaml um.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Zur Errechnung der Broadcast Adresse des 1. Netzes setzen wir alle nicht durch die Subnetzmaske gesperrte Bits auf 1 und rechnen sie in Deziaml um.",
      "autoResize": true,
      "lineHeight": 1.25
    },
