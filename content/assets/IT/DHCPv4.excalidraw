    {
      "id": "vbBnTBZfkJv5Y5l0Tn_zv",
      "type": "text",
      "x": 567.311342591298,
      "y": 1617.4291769485922,
      "width": 1188.4791259765625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
