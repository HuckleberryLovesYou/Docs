      "updated": 1773914344184,
      "link": null,
      "locked": false,
      "text": "Errechnung der Netzwerkadresse:\n\nNetzwerkadresse ist die Adresse, bei welche alle Host-Bits 0 sind. Das ist in dem Beispiel schon erledigt.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Errechnung der Netzwerkadresse:\n\nNetzwerkadresse ist die Adresse, bei welche alle Host-Bits 0 sind. Das ist in dem Beispiel schon erledigt.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AIBC7OuXRvz27YzYZnTt0",
      "type": "text",
      "x": 575.9999389648438,
      "y": 712.7999877929688,
      "width": 308.25,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ad",
      "roundness": null,
      "seed": 1059191445,
      "version": 56,
