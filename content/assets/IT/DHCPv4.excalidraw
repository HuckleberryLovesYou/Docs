      "link": null,
      "locked": false,
      "text": "Danach müssen die Netze eingeteilt werden. Hierfür zählen wir später einfach den Bereich, den die Subnetzmaske nun mehr bedeckt immer binär pro Netz um 1 hoch. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Danach müssen die Netze eingeteilt werden. Hierfür zählen wir später einfach den Bereich, den die Subnetzmaske nun mehr bedeckt immer binär pro Netz um 1 hoch. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
