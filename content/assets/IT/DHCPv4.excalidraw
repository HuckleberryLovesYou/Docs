      "isDeleted": true,
      "boundElements": [],
      "updated": 1773914344184,
      "link": null,
      "locked": false,
      "text": "192.168.{1111 1110.0000 0000}\n255.255.{1111 1110.0000 0000}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "192.168.{1111 1110.0000 0000}\n255.255.{1111 1110.0000 0000}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "A06Iu3HnSAwAQk3Rxf7WU",
      "type": "text",
      "x": 574.9999389648438,
      "y": 787.5999755859375,
      "width": 1142.7708740234375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ah",
      "roundness": null,
      "seed": 75186229,
      "version": 354,
      "versionNonce": 773966686,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773914344184,
      "link": null,
      "locked": false,
      "text": "Das ist bei der der IP 192.168.254.0 einfach, da es sich um eine Netzwerkadresse handelt. Es kann aber auch z.B.\ndie IP 192.168.255.11/23 gegeben sein. Hier schreibt man die IP und Subnetzmaske gleich wie oben untereinander auf.\nDanach setzt man alle Bits, welche nicht durch die Subnetzmaske blockiert werden auf 0.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Das ist bei der der IP 192.168.254.0 einfach, da es sich um eine Netzwerkadresse handelt. Es kann aber auch z.B.\ndie IP 192.168.255.11/23 gegeben sein. Hier schreibt man die IP und Subnetzmaske gleich wie oben untereinander auf.\nDanach setzt man alle Bits, welche nicht durch die Subnetzmaske blockiert werden auf 0.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
